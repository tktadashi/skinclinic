rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'pwglobalwf@gmail.com' || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    function isValidBook(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             (!('description' in data.keys()) || (data.description is string && data.description.size() <= 5000)) &&
             data.price is number && data.price >= 0 &&
             data.kiwifyLink is string && data.kiwifyLink.size() <= 500 &&
             (!('coverUrl' in data.keys()) || (data.coverUrl is string && data.coverUrl.size() <= 1000)) &&
             data.createdAt is timestamp;
    }
    
    function isValidPost(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 50000 &&
             (!('coverUrl' in data.keys()) || (data.coverUrl is string && data.coverUrl.size() <= 1000)) &&
             data.createdAt is timestamp;
    }
    
    match /books/{bookId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(bookId) && isValidBook(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidId(bookId) && isValidBook(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'kiwifyLink', 'coverUrl']);
      allow delete: if isAdmin();
    }
    
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(postId) && isValidPost(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidId(postId) && isValidPost(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'coverUrl']);
      allow delete: if isAdmin();
    }
    
    match /admins/{userId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
